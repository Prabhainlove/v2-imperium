# Local Imperium agent — fully offline. No Supabase, no API keys required.
HOST=127.0.0.1
PORT=8000
HEADLESS=0
# Optional: where to persist run state across restarts
STATE_FILE=./agent_state.json

# ---- Security (REQUIRED for /apply, /approve, /reject, /status, /events, /runs) ----
# Shared secret between the web app and this local agent. Generate a random
# 32+ char string (e.g. `python -c "import secrets; print(secrets.token_urlsafe(32))"`).
# The web app must set the SAME value as VITE_LOCAL_AGENT_TOKEN in its own .env.
# If unset, the agent only exposes /health and refuses everything else.
IMPERIUM_AGENT_TOKEN=

# Comma-separated list of origins the web app is served from.
# Default covers common Vite/Next dev ports on localhost + 127.0.0.1.
IMPERIUM_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# ---- B8: HMAC callback back to the web app (optional) ----
# Where to POST terminal run state. Typically:
#   http://localhost:3000/api/public/agent-callback  (dev)
#   https://your-app.lovable.app/api/public/agent-callback  (prod)
# Leave blank to disable callbacks.
IMPERIUM_CALLBACK_URL=
# Shared secret used to sign the POST body with HMAC-SHA256. Must equal
# IMPERIUM_CALLBACK_SECRET in the web app's .env.
IMPERIUM_CALLBACK_SECRET=
# Per-request timeout in seconds (optional, default 10).
IMPERIUM_CALLBACK_TIMEOUT=10

# ---- Chrome profile ----------------------------------------------------
# By default the agent uses a DEDICATED persistent profile at
#   ~/.imperium_chrome_profile
# Log in to LinkedIn / Google ONCE in that window and the session sticks
# forever, without ever colliding with your real Chrome.
#
# Set USE_REAL_CHROME=1 to reuse your everyday Chrome "User Data" folder.
# In that case you MUST fully close every Chrome window (including the
# system-tray icon) before starting the agent — Chrome refuses to open
# the same profile twice and you'll get "chrome not reachable".
USE_REAL_CHROME=0

# Override the profile location entirely (optional):
#   Windows: C:\Users\<you>\AppData\Local\Google\Chrome\User Data
#   macOS:   ~/Library/Application Support/Google/Chrome
#   Linux:   ~/.config/google-chrome
CHROME_USER_DATA_DIR=
CHROME_PROFILE_DIR=Default

# ---- Local LLM brain (Ollama) ------------------------------------------
# Install Ollama from https://ollama.com, then:
#   ollama pull qwen2.5:7b           # recommended (good JSON, ~5GB RAM)
#   ollama pull llama3.2:3b          # low-RAM fallback (~3GB RAM)
# Agent auto-detects Ollama; if offline it falls back to pure heuristics.
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT=30

# Optional: path to your resume PDF (uploaded automatically when a form
# has a file input).
# RESUME_PATH=C:\Users\dinesh\Documents\resume.pdf
