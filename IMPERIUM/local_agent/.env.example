# Local Imperium agent — fully offline. No Supabase, no API keys required.
HOST=127.0.0.1
PORT=8000
HEADLESS=0
# Optional: where to persist run state across restarts
STATE_FILE=./agent_state.json
# Optional: allow the web UI origin (comma separated). * = allow all (dev only).
CORS_ORIGINS=*

# ---- Chrome profile ----------------------------------------------------
# By default the agent uses a DEDICATED persistent profile at
#   ~/.imperium_chrome_profile
# Log in to LinkedIn / Google ONCE in that window and the session sticks
# forever, without ever colliding with your real Chrome.
#
# Set USE_REAL_CHROME=1 to reuse your everyday Chrome "User Data" folder.
# In that case you MUST fully close every Chrome window (including the
# system-tray icon) before starting the agent — Chrome refuses to open
# the same profile twice and you'll get "chrome not reachable".
USE_REAL_CHROME=0

# Override the profile location entirely (optional):
#   Windows: C:\Users\<you>\AppData\Local\Google\Chrome\User Data
#   macOS:   ~/Library/Application Support/Google/Chrome
#   Linux:   ~/.config/google-chrome
CHROME_USER_DATA_DIR=
CHROME_PROFILE_DIR=Default
