# Copy to .env and fill in.

SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...service-role-key...

# Shared token: any random string. Must match what the frontend stamps onto
# the automation_runs row. Prevents a stray agent from picking up someone
# else's run if multiple users share a Supabase project.
IMPERIUM_AGENT_TOKEN=local-dev-token

# false = visible Chromium window (recommended so you can watch)
HEADLESS=false

# How often (seconds) to poll for new queued runs.
POLL_INTERVAL=2
