{
  "agent_name": "JARVIS Automation Agent",
  "version": "1.0.0",
  "description": "Complete system automation agent with 90+ capabilities",
  "capabilities": {
    "browser_automation": {
      "enabled": true,
      "features": [
        "web_navigation",
        "form_filling",
        "data_scraping",
        "authentication",
        "screenshots",
        "javascript_execution"
      ]
    },
    "os_control": {
      "enabled": true,
      "features": [
        "application_launch",
        "process_management",
        "keyboard_simulation",
        "mouse_control",
        "command_execution"
      ]
    },
    "file_system": {
      "enabled": true,
      "features": [
        "file_operations",
        "folder_organization",
        "file_search",
        "bulk_operations"
      ]
    },
    "workflows": {
      "enabled": true,
      "features": [
        "multi_step_execution",
        "conditional_logic",
        "error_handling",
        "parallel_execution"
      ]
    },
    "api_integration": {
      "enabled": true,
      "features": [
        "http_requests",
        "webhooks",
        "rest_api"
      ]
    },
    "monitoring": {
      "enabled": true,
      "features": [
        "resource_tracking",
        "process_monitoring",
        "disk_usage"
      ]
    },
    "safety": {
      "level": "strict",
      "features": [
        "command_validation",
        "dangerous_operation_blocking",
        "confirmation_prompts"
      ]
    }
  },
  "dependencies": {
    "required": [],
    "optional": [
      "playwright",
      "pyautogui",
      "psutil",
      "aiohttp"
    ]
  },
  "integration": {
    "imperium_compatible": true,
    "execution_method": "async execute(task: dict) -> dict"
  }
}
